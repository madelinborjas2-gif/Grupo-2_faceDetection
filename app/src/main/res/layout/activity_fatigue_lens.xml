<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fl_surface"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:paddingLeft="16dp"
    android:paddingTop="28dp"
    android:paddingRight="16dp">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_eye"
            app:tint="@color/fl_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:fontFamily="sans"
            android:text="FatigueLens"
            android:textColor="@color/fl_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Configuración"
            android:padding="8dp"
            android:src="@drawable/ic_settings"
            app:tint="@color/fl_primary" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="false"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:id="@+id/previewCard"
                android:layout_width="match_parent"
                android:layout_height="390dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_preview_card"
                android:clipToOutline="true"
                android:padding="14dp">

                <ImageView
                    android:id="@+id/imagePreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_camera_placeholder" />

                <TextView
                    android:id="@+id/previewText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="72dp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.08"
                    android:text="VISTA PREVIA"
                    android:textColor="@color/fl_outline_variant"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_preview_corners" />
            </FrameLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCamera"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/btn_primary_selector"
                app:backgroundTint="@null"
                app:icon="@drawable/ic_camera_small"
                app:iconTint="@color/btn_text_selector"
                app:iconGravity="textStart"
                android:fontFamily="sans"
                android:text="Capturar con Cámara"
                android:textAllCaps="false"
                android:textColor="@color/btn_text_selector"
                android:textSize="15sp"
                android:textStyle="bold"
                app:cornerRadius="26dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGallery"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/btn_primary_selector"
                app:backgroundTint="@null"
                app:icon="@drawable/ic_gallery_small"
                app:iconTint="@color/btn_text_selector"
                app:iconGravity="textStart"
                android:fontFamily="sans"
                android:text="Seleccionar de Galería"
                android:textAllCaps="false"
                android:textColor="@color/btn_text_selector"
                android:textSize="15sp"
                android:textStyle="bold"
                app:cornerRadius="26dp" />

            <LinearLayout
                android:id="@+id/guideCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_guide_card"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_gold_dot" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.08"
                        android:text="GUÍA DE USO"
                        android:textColor="@color/fl_primary_container"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="sans"
                    android:lineSpacingExtra="2dp"
                    android:text="Asegúrate de que la iluminación sea adecuada y que tu rostro esté centrado para una detección de fatiga óptima mediante nuestra IA."
                    android:textColor="@color/fl_on_surface_variant"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:gravity="center"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_home"
                app:tint="@color/fl_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="Inicio"
                android:textColor="@color/fl_primary"
                android:textSize="10sp"
                android:textStyle="bold" />

            <View
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:layout_marginTop="2dp"
                android:background="@drawable/bg_gold_dot" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navAnalysis"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:alpha="0.45"
                android:src="@drawable/ic_analysis"
                app:tint="@color/fl_outline" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.55"
                android:fontFamily="monospace"
                android:text="Análisis"
                android:textColor="@color/fl_outline"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
